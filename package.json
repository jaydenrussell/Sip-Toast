{
  "name": "sip-caller-id",
  "version": "1.0.25",
  "description": "SIP Caller ID application",
  "author": "Jayden Russell",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never",
    "test": "mocha test/**/*.js",
    "package:squirrel": "electron-builder --win --x64 --publish never",
    "build:squirrel": "npm run package:squirrel && npm run create-nuget-packages",
    "create-nuget-packages": "node scripts/create-nuget-packages.js",
    "build-and-release": "node scripts/build-and-release.js",
    "build:electron-builder": "electron-builder --win --x64 --publish never",
    "clean": "rm -rf build dist"
  },
  "build": {
    "appId": "com.siptoast.app",
    "productName": "SIP Caller ID",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "Images/**/*",
      "package.json",
      "!**/*.map",
      "!**/test/**/*",
      "!**/__tests__/**/*",
      "!**/tests/**/*"
    ],
    "win": {
      "target": "squirrel",
      "icon": "Images/app.ico",
      "artifactName": "SIPCallerID-Setup-${version}.exe"
    }
  },
  "dependencies": {
    "conf": "^15.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "sip": "^0.0.6"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "mocha": "^11.7.5"
  },
  "buildDate": "2026-03-05T05:21:19.383Z"
}